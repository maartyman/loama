{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
        "env.d.ts",
        "src/**/*",
        "src/**/*.vue"
    ],
    "exclude": [
        "src/**/__tests__/*"
    ],
    "compilerOptions": {
        "composite": true,
        "verbatimModuleSyntax": false,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*",
                "./tests/*"
            ],
            "loama-app": [
                "./src/libs/loama-app/index.ts"
            ],
            "loama-common": [
                "./src/libs/loama-common/index.ts"
            ],
            "loama-controller": [
                "./src/libs/loama-controller/index.ts"
            ]
        }
    }
}
